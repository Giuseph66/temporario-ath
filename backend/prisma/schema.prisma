generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Multi-tenant SaaS — Sprint A ─────────────────────────────────────────────

model Tenant {
  id                String       @id @default(uuid())
  name              String
  slug              String       @unique
  plan              String       @default("free")
  evolutionInstance String?
  evolutionApiKey   String?
  evolutionBaseUrl  String?
  geminiApiKey      String?
  asaasApiKey       String?
  asaasBaseUrl      String?      @default("https://sandbox.asaas.com/api/v3")
  asaasWebhookSecret String?
  metaAccessToken   String?
  metaPhoneId       String?
  metaVerifyToken   String?
  googleCalendarId  String?
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())

  users             User[]
  agents            Agent[]
  tenantUsers       TenantUser[]
  googleCalendarIntegrations UserGoogleCalendarIntegration[]
  knowledgeDocs       KnowledgeDocument[]
  contacts            Contact[]
  simulatorSessions   SimulatorSession[]
  automations         Automation[]
  automationRuns      AutomationRun[]
}

model TenantUser {
  id           String    @id @default(uuid())
  tenantId     String
  email        String    @unique
  passwordHash String
  role         String    @default("admin")
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())

  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  googleCalendarIntegration UserGoogleCalendarIntegration?
}

enum GoogleCalendarIntegrationStatus {
  CONNECTED
  ERROR
  REVOKED
  EXPIRED
}

model UserGoogleCalendarIntegration {
  id          String                          @id @default(uuid())
  tenantUserId String                        @unique
  tenantId    String
  googleEmail String?
  accessToken String?
  refreshToken String?
  expiresAt   DateTime?
  scopes      Json?
  status      GoogleCalendarIntegrationStatus @default(CONNECTED)
  lastError   String?
  connectedAt DateTime?
  revokedAt   DateTime?
  createdAt   DateTime                        @default(now())
  updatedAt   DateTime                        @updatedAt

  tenantUser  TenantUser @relation(fields: [tenantUserId], references: [id], onDelete: Cascade)
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
}

model Agent {
  id             String   @id @default(uuid())
  tenantId       String

  // ─── Persona (scalar fields) ────────────────────────────────────────────────
  name           String                        // Nome do agente (ex: "Artemis")
  role           String   @default("") @db.Text // Instrução de papel / system prompt base
  language       String   @default("Português (BR)")
  geminiModel    String   @default("gemini-2.5-flash")
  isActive       Boolean  @default(true)
  whatsappNumber String?

  // ─── Persona (editorial blobs — semi-structured, não precisam de join) ──────
  toneJson               Json?  // { primary: string[], formatting, ai_identity, emoji_rules }
  qualificationJson      Json?  // string[] — regras de qualificação do lead
  objectionHandlingJson  Json?  // { tactics, layer_1_soft, layer_2_medium, layer_3_direct }
  knowledgeContractsJson Json?  // { rules, bonuses, evolution }

  // ─── Settings (scalar) ──────────────────────────────────────────────────────
  whitelistEnabled        Boolean @default(false)
  ignoreGroups            Boolean @default(true)
  adminChatEnabled        Boolean @default(true)
  agentInternalMode       String  @default("orientador") // orientador | simulador
  ownerPhone              String?
  humanSupportNumber      String?
  humanHandoffMessage     String? @db.Text
  humanNotificationNumber String?

  // ─── Campos legados — mantidos nullable durante transição ───────────────────
  personaJson    Json?
  programsJson   Json?
  settingsJson   Json?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leads          User[]
  programs       AgentProgram[]
  protocols      AgentProtocol[]
  restrictions   AgentRestriction[]
  whitelistPhones WhitelistPhone[]
  whitelistGroups WhitelistGroup[]
}

// ─── Programas do agente ──────────────────────────────────────────────────────
model AgentProgram {
  id            String   @id @default(uuid())
  agentId       String
  programKey    String                   // slug único (ex: "ingles_personalizado")
  name          String
  priceValue    Float    @default(0)
  priceType     String   @default("monthly") // monthly | per_session
  installments  Int      @default(1)
  durationWeeks Int      @default(0)
  verbatimIntro String   @default("") @db.Text
  fullText      String   @default("") @db.Text
  sortOrder     Int      @default(0)

  agent         Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, programKey])
  @@index([agentId])
}

// ─── Protocolos do agente (key/value) ─────────────────────────────────────────
model AgentProtocol {
  id      String @id @default(uuid())
  agentId String
  key     String
  value   String @db.Text

  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, key])
  @@index([agentId])
}

// ─── Restrições absolutas do agente ──────────────────────────────────────────
model AgentRestriction {
  id        String @id @default(uuid())
  agentId   String
  text      String @db.Text
  sortOrder Int    @default(0)

  agent     Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
}

// ─── Whitelist de contatos individuais ───────────────────────────────────────
model WhitelistPhone {
  id      String @id @default(uuid())
  agentId String
  phone   String

  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, phone])
  @@index([agentId])
}

// ─── Whitelist de grupos ──────────────────────────────────────────────────────
model WhitelistGroup {
  id      String @id @default(uuid())
  agentId String
  groupId String

  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, groupId])
  @@index([agentId])
}

// ─── Controle de idempotência do webhook Asaas ────────────────────────────────

model ProcessedEvent {
  id          String   @id
  processedAt DateTime @default(now())
}

// ─── Status de matrícula ──────────────────────────────────────────────────────

enum EnrollmentStatus {
  LEAD
  PAYMENT_PENDING
  ENROLLED
  CANCELLED
}

// ─── Leads / Alunos ───────────────────────────────────────────────────────────

model User {
  id               String           @id @default(uuid())
  tenantId         String?
  agentId          String?
  phoneNumber      String
  name             String?
  age              Int?
  goal             String?
  currentProgramId String?
  conversationState String?          @default("GREETING")
  interactionCount Int              @default(0)
  lastInteraction  DateTime         @default(now())
  createdAt        DateTime         @default(now())
  cpf              String?
  email            String?
  birthDate        String?
  address          String?
  paymentDay       Int?
  enrollmentTarget String?
  extraInfo        String?
  isGroup          Boolean          @default(false)
  lgpdConsent      Boolean          @default(false)
  asaasCustomerId  String?          @unique
  lastPaymentUrl   String?
  enrollmentStatus EnrollmentStatus @default(LEAD)
  enrollmentDate   DateTime?

  tenant           Tenant?          @relation(fields: [tenantId], references: [id])
  agent            Agent?           @relation(fields: [agentId], references: [id])
  messages         ChatHistory[]
  automationTargets AutomationTargetRun[]

  @@unique([phoneNumber, tenantId])
}

// ─── Automações Contextuais ──────────────────────────────────────────────────

model Automation {
  id               String   @id @default(uuid())
  tenantId         String
  name             String
  type             String
  status           String   @default("DRAFT")
  triggerType      String
  scheduleJson     Json     @default("{}")
  targetJson       Json     @default("{}")
  conditionsJson   Json     @default("{}")
  actionJson       Json     @default("{}")
  limitsJson       Json     @default("{}")
  requiresApproval Boolean  @default(false)
  nextRunAt        DateTime?
  lastRunAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  runs             AutomationRun[]
  targetRuns       AutomationTargetRun[]

  @@index([tenantId])
  @@index([status, nextRunAt])
  @@index([triggerType])
}

model AutomationRun {
  id             String   @id @default(uuid())
  tenantId       String
  automationId   String
  status         String   @default("RUNNING")
  startedAt      DateTime @default(now())
  finishedAt     DateTime?
  sentCount      Int      @default(0)
  skippedCount   Int      @default(0)
  failedCount    Int      @default(0)
  error          String?  @db.Text
  triggerPayload Json?

  tenant         Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  automation     Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  targets        AutomationTargetRun[]

  @@index([tenantId])
  @@index([automationId, startedAt])
}

model AutomationTargetRun {
  id            String   @id @default(uuid())
  tenantId      String
  automationId  String
  runId         String
  userId        String?
  status        String
  reason        String?  @db.Text
  message       String?  @db.Text
  trace         Json?
  createdAt     DateTime @default(now())

  automation    Automation  @relation(fields: [automationId], references: [id], onDelete: Cascade)
  run           AutomationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  user          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([automationId, userId, createdAt])
  @@index([runId])
}

// ─── Cache de contatos da Evolution ─────────────────────────────────────────

model Contact {
  id            String   @id @default(uuid())
  tenantId      String
  phone         String
  name          String?
  customName    String?
  profilePicUrl String?
  syncedAt      DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, phone])
  @@index([tenantId])
}

// ─── RAG — Base de Conhecimento ──────────────────────────────────────────────

model KnowledgeDocument {
  id        String   @id @default(uuid())
  tenantId  String
  title     String
  content   String   @db.Text
  charCount Int      @default(0)
  createdAt DateTime @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chunks    KnowledgeChunk[]
}

model KnowledgeChunk {
  id            String                   @id @default(uuid())
  tenantId      String
  documentId    String
  chunkIndex    Int
  content       String                   @db.Text
  embeddingJson String                   @db.Text  // fallback JSON — kept for backup/export
  embedding     Unsupported("vector(768)")?        // pgvector — used for HNSW search
  createdAt     DateTime                 @default(now())

  document      KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ─── Sessões do Simulador ─────────────────────────────────────────────────────

model SimulatorSession {
  id          String   @id @default(uuid())
  tenantId    String
  title       String   @default("Nova sessão")
  agentType   String   @default("atendente")
  convState   String   @default("GREETING")
  simMode     String   @default("cliente")
  messages    Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ─── Histórico de Conversas ───────────────────────────────────────────────────

model ChatHistory {
  id        String   @id @default(uuid())
  userId    String
  role      String
  content   String
  trace     Json?
  media     Json?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
